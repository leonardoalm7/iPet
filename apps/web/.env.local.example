# Supabase — mesmo projeto do app nativo
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role — server-only (webhook checkout, cron push, /api/events, /admin/metricas)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admins — e-mails com acesso a /admin/metricas (separados por vírgula)
ADMIN_EMAILS=socio1@ipet.com.br,socio2@ipet.com.br

# URL pública do website (OAuth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Anthropic — OCR de documentos veterinários
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps — mapa de clínicas parceiras
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Mercado Pago Checkout Pro — criar-preferencia + webhook
# Painel: developers.mercadopago.com.br → sua aplicação → Credenciais de teste/produção
MERCADOPAGO_ACCESS_TOKEN=TEST-... (ou APP_USR-... em produção)
