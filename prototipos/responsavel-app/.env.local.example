# ============================================================
# iPet — Variáveis de Ambiente (copie para .env.local)
# ============================================================
# NÃO commitar o arquivo .env.local — ele está no .gitignore

# ─── Supabase ─────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── URL da aplicação ─────────────────────────────────────
# Em desenvolvimento: http://localhost:3000
# Em produção: https://app.ipet.app

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Google Maps (opcional — para sugestão de clínicas) ───
# Encontre em: console.cloud.google.com → APIs & Services → Credentials

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ─── Anthropic API (OCR de carteira de vacinação) ────────
# Encontre em: console.anthropic.com → Settings → API Keys
# Server-side only — NÃO usar prefixo NEXT_PUBLIC_ (vaza no bundle)

ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Firebase Cloud Messaging (opcional — notificações) ───
# Encontre em: console.firebase.google.com → Project Settings → General

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ipet-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ipet-app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000000000

# ─── Configuração OAuth no Supabase ───────────────────────
# Configure em: Supabase Dashboard → Authentication → Providers
#
# Google OAuth:
#   - Redirect URL para o Supabase: https://xxxxxxxxxxxxxxxxxxx.supabase.co/auth/v1/callback
#   - No Google Cloud Console: adicione como Authorized redirect URI
#
# Apple OAuth:
#   - Requer Apple Developer Account
#   - Redirect URL: https://xxxxxxxxxxxxxxxxxxx.supabase.co/auth/v1/callback
#   - Configure Services ID, Team ID e Key ID no Supabase
#
# Redirect após auth (no Supabase Dashboard → Authentication → URL Configuration):
#   Site URL: http://localhost:3000
#   Redirect URLs: http://localhost:3000/auth/callback
